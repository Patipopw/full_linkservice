# --- Database Configuration (PostgreSQL) ---
# รูปแบบ: postgresql://user:password@localhost:5432/db_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/linkservice_db

# --- Security & Auth ---
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- File Upload Configuration ---
UPLOAD_ROOT_DIR=uploads

# --- Server URL ---
# สำหรับ @computed_field ในการสร้าง URL เต็ม
BASE_URL=http://localhost:8000
